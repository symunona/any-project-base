# Copy this to .env.local and fill in values.
# Run: just setup  — to walk through each one interactively.
# Run: just setup health  — to see which are missing + implications.

# ── App ───────────────────────────────────────────────
VITE_APP_ENV=local                     # local | test | prod
VITE_PROJECT_NAME=any-project-base
VITE_DOMAIN=any-project-base.com
VITE_PRICING_MODEL=none                # none | credits | subscription_credits | tiers
VITE_ANALYTICS=none                    # none | posthog
VITE_AUTH_PROVIDERS=email              # comma-separated
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en              # comma-separated

# ── Supabase ──────────────────────────────────────────
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:54321/functions/v1
SUPABASE_SERVICE_ROLE_KEY=             # server-side only, never expose to frontend
SUPABASE_DB_PASSWORD=

# ── Stripe (pricing_model != none) ────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ── PostHog (analytics: posthog) ──────────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Firebase / FCM (push_notifications: firebase) ─────
FIREBASE_SERVICE_ACCOUNT_JSON=         # path to service account JSON
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=               # for web push

# ── Email / SMTP ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@any-project-base.com

# ── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sentry (error_monitoring: sentry) ─────────────────
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
