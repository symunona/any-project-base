# .env.local — copy this file, fill in what's needed.
#
# FASTEST SETUP:
#   1. just start          — start Supabase (Docker)
#   2. just env-generate   — auto-fills everything derivable (project.yaml + supabase status)
#   3. just setup-stripe   — paste 2 Stripe keys (if billing enabled)
#   4. just setup-firebase — one `firebase login`, rest is auto (if mobile enabled)
#   5. just status         — see what's still missing

# ══════════════════════════════════════════════════
# AUTO-FILLED — `just env-generate` sets these
# Edit project.yaml instead of changing these directly.
# ══════════════════════════════════════════════════

VITE_APP_ENV=local
# Canonical URL of the client portal — used for auth redirects (magic links, OAuth callbacks).
# Dev: auto-set by env-generate. Prod: set to your production portal URL.
# Used in supabase/config.toml as site_url = "env(SITE_URL)"
SITE_URL=
VITE_APP_URL=
VITE_PROJECT_NAME=any-project-base
VITE_DOMAIN=any-project-base.com
VITE_PRICING_MODEL=none
VITE_ANALYTICS=none
VITE_AUTH_PROVIDERS=email
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en

# ── Supabase local — auto-filled after `just start` ──
VITE_SUPABASE_URL=http://localhost:54321
VITE_API_URL=http://localhost:54321/functions/v1
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ══════════════════════════════════════════════════
# BILLING — required when pricing_model != none
# Setup: just setup-stripe
# Docs: https://dashboard.stripe.com → Developers → API keys
# ══════════════════════════════════════════════════

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=  # auto: copied from STRIPE_PUBLISHABLE_KEY by env-generate

# Local dev: `just db-stripe-listen` prints this automatically.
# Prod: Stripe Dashboard → Developers → Webhooks → Signing secret.
STRIPE_WEBHOOK_SECRET=

# ══════════════════════════════════════════════════
# MOBILE + PUSH — required when push_notifications: firebase
# Setup: just setup-firebase (auto-fills most via `firebase` CLI)
# Most vars below are auto-filled — only VAPID key needs manual copy.
# ══════════════════════════════════════════════════

FIREBASE_SERVICE_ACCOUNT_JSON=      # path to downloaded service account JSON
VITE_FIREBASE_PROJECT_ID=           # auto: extracted from service account
VITE_FIREBASE_AUTH_DOMAIN=          # auto: {project_id}.firebaseapp.com
VITE_FIREBASE_API_KEY=              # auto: firebase apps:sdkconfig
VITE_FIREBASE_MESSAGING_SENDER_ID=  # auto: firebase apps:sdkconfig
VITE_FIREBASE_APP_ID=               # auto: firebase apps:sdkconfig
VITE_FIREBASE_VAPID_KEY=            # manual: Firebase console → Cloud Messaging → Web Push certificates

# ══════════════════════════════════════════════════
# ANALYTICS — required when analytics: posthog
# Setup: just setup-posthog
# Docs: https://app.posthog.com → Settings → Project API Key
# ══════════════════════════════════════════════════

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com  # auto: default

# ══════════════════════════════════════════════════
# EMAIL / SMTP
# Local dev: skip — Supabase Inbucket at http://localhost:54324
# Prod: any SMTP provider (Postmark, Resend, SendGrid...)
# Setup: just setup-env to fill these interactively
# ══════════════════════════════════════════════════

SMTP_HOST=
SMTP_PORT=587                              # auto: default
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@any-project-base.com     # auto: noreply@{domain}

# ══════════════════════════════════════════════════
# GOOGLE OAUTH — required when auth_providers includes google
# Docs: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# ══════════════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ══════════════════════════════════════════════════
# ERROR MONITORING — required when error_monitoring: sentry
# Docs: https://sentry.io → Settings → Developer Settings → Auth Tokens
# ══════════════════════════════════════════════════

VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ══════════════════════════════════════════════════
# LLM — required for /api/llm/chat
# Docs: https://console.anthropic.com → API Keys
# Synced to supabase/functions/.env by env-generate
# ══════════════════════════════════════════════════

ANTHROPIC_API_KEY=

# ══════════════════════════════════════════════════
# EXTERNAL APIs
# Synced to supabase/functions/.env by env-generate
# ══════════════════════════════════════════════════

DATA_GO_KR_API_KEY=
